@startuml hello_world

skinparam classAttributeIconSize 0

' ── Interface parcel ────────────────────────────────────────────────
interface "output / _" as IOutput <<parcel _>> {
  + {typedef} Greeting
  + {typedef} Output
}
note right of IOutput
  output.c
  #pragma parcel _ { Greeting Output }
  export/output
end note

' ── Implementation: stdout ──────────────────────────────────────────
class "output / stdout" as Stdout <<parcel stdout>> {
  + output(greeting : out_Greeting) : void
}
note right of Stdout
  output/stdout.c
  import/output/_.out
  #pragma parcel stdout { output }
  export/output/stdout
end note

' ── Implementation: null ────────────────────────────────────────────
class "output / null" as Null <<parcel null>> {
  + output(greeting : out_Greeting) : void
}
note right of Null
  output/null.c
  import/output/_.out
  #pragma parcel null { output }
  export/output/null
end note

' ── Selector header ─────────────────────────────────────────────────
class "output.h" as Header <<header>> {
  + {macro} OUTPUT_NULL
  + {macro} OUT
}
note right of Header
  #include "import/output/_.out"
  #if defined(OUTPUT_NULL)
    #include "import/output/null.null"
    #define OUT null
  #else
    #include "import/output/stdout.std"
    #define OUT std
  #endif
end note

' ── Consumer ────────────────────────────────────────────────────────
class "main" as Main {
  + greeting : out_Greeting
  --
  + main() : int
}
note right of Main
  #include "output.h"
  OUT->output(greeting)
  (-DOUTPUT_NULL to select null)
end note

' ── Relationships ───────────────────────────────────────────────────
Stdout ..|> IOutput : conforms to
Null   ..|> IOutput : conforms to

Header ..> IOutput : imports\n«stem: out»
Header ..> Stdout  : imports conditionally\n«stem: std»
Header ..> Null    : imports conditionally\n«stem: null»

Main ..> Header : includes

@enduml
